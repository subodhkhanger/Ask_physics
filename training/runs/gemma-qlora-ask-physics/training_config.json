{
  "data": {
    "eval_file": "training/data/sft_balanced/dev.jsonl",
    "max_seq_length": 1024,
    "preprocessing_num_workers": 1,
    "train_file": "training/data/sft_balanced/train.jsonl"
  },
  "generation": {
    "max_new_tokens": 512,
    "temperature": 0.0,
    "top_p": 1.0
  },
  "lora": {
    "bias": "none",
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "r": 8,
    "target_modules": [
      "q_proj.linear",
      "k_proj.linear",
      "v_proj.linear",
      "o_proj.linear",
      "gate_proj.linear",
      "up_proj.linear",
      "down_proj.linear"
    ],
    "task_type": "CAUSAL_LM"
  },
  "model": {
    "attn_implementation": "eager",
    "base_model": "google/gemma-4-E4B-it",
    "torch_dtype": "bfloat16",
    "trust_remote_code": false
  },
  "output": {
    "hub_model_id": null,
    "output_dir": "training/runs/gemma-qlora-ask-physics",
    "push_to_hub": false,
    "save_total_limit": 2
  },
  "quantization": {
    "bnb_4bit_compute_dtype": "bfloat16",
    "bnb_4bit_quant_type": "nf4",
    "bnb_4bit_use_double_quant": true,
    "load_in_4bit": true
  },
  "run_name": "ask-physics-gemma-qlora-v0.1",
  "training": {
    "bf16": true,
    "eval_steps": 100,
    "eval_strategy": "steps",
    "fp16": false,
    "gradient_accumulation_steps": 16,
    "gradient_checkpointing": true,
    "learning_rate": 0.0002,
    "logging_steps": 10,
    "lr_scheduler_type": "cosine",
    "max_grad_norm": 0.3,
    "num_train_epochs": 2,
    "optim": "paged_adamw_8bit",
    "per_device_eval_batch_size": 1,
    "per_device_train_batch_size": 1,
    "report_to": [
      "tensorboard"
    ],
    "save_steps": 100,
    "save_strategy": "steps",
    "seed": 42,
    "warmup_ratio": 0.03,
    "weight_decay": 0.0
  }
}