{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ask-physics.local/schemas/sft_chat.schema.json",
  "title": "Ask Physics SFT Chat Record",
  "type": "object",
  "required": ["schema_version", "paper_id", "task", "messages"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "sft_chat.v1"
    },
    "paper_id": {
      "type": "string",
      "pattern": "^arxiv:"
    },
    "task": {
      "type": "string",
      "enum": ["abstract_measurement_extraction", "query_parsing"]
    },
    "messages": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string"
          }
        }
      }
    }
  }
}
